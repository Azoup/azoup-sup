# Copie para ".env" e preencha. Não commite o ficheiro ".env".

# --- Front (Vite) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SITE_URL=
VITE_PASSWORD_RESET_VIA_EMAILJS=true

# --- Edge Function password-reset-email ---
# Enviar para o Supabase: supabase secrets set --env-file .env --project-ref SEU_PROJECT_REF
# Servir funções à máquina: supabase functions serve --env-file .env
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
# Opcional, só se "Use Private Key" estiver ativo no EmailJS:
# EMAILJS_PRIVATE_KEY=
