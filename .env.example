# Copie para ".env" na raiz. Não commite o ficheiro ".env".
#
# IMPORTANTE: VITE_SUPABASE_URL e VITE_SUPABASE_PUBLISHABLE_KEY devem ser do MESMO
# projeto Supabase onde existem as contas de utilizador (Auth) e os dados da app.
# Se mudar para outro project-ref sem migrar utilizadores, o login falha com
# "email ou senha incorretos" mesmo com credenciais certas.
#
# Ações de admin (excluir utilizador / definir senha) usam a API na Vercel:
#   POST /api/admin-user-action  (requer SUPABASE_SERVICE_ROLE_KEY só no servidor)
#
# Painel Supabase → Project Settings → API:
#   - Project URL  → VITE_SUPABASE_URL
#   - anon / publishable key → VITE_SUPABASE_PUBLISHABLE_KEY
#
# Replique as mesmas variáveis VITE_* na Vercel (Settings → Environment Variables).

VITE_SUPABASE_URL=https://ittmglvkympbyeowgucl.supabase.co
VITE_SUPABASE_PROJECT_ID=ittmglvkympbyeowgucl
# anon/publishable key do MESMO projeto (ittmglvk) — Settings → API → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SITE_URL=https://azoup-sup.vercel.app

# service_role do MESMO projeto (ittmglvk). Obrigatória para admin definir senha de outro usuário.
# Local: .env | Produção: Vercel → Environment Variables (sem prefixo VITE_)
SUPABASE_SERVICE_ROLE_KEY=

# Migração de Storage (projeto antigo → ittmglvk). Só para rodar migrate:storage localmente.
# OLD_SUPABASE_URL=https://ffvgrvrkuiypjzfdcfyw.supabase.co
# OLD_SUPABASE_SERVICE_ROLE_KEY=
