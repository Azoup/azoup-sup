# Copie para ".env" e preencha. Não commite o ficheiro ".env".

# --- Front (Vite) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SITE_URL=
# true = recuperação por código (EmailJS + Edge Functions); false = e-mail/link nativo do Supabase
VITE_PASSWORD_RESET_VIA_EMAILJS=true

# --- Edge Functions (password-reset-request-code + password-reset-confirm-code) ---
# supabase secrets set --env-file .env --project-ref SEU_PROJECT_REF
# supabase functions serve --env-file .env
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
# Opcional se "Use Private Key" no EmailJS:
# EMAILJS_PRIVATE_KEY=
# Obrigatório para OTP: string longa e secreta (não reutilizar noutro sítio)
PASSWORD_RESET_CODE_PEPPER=
